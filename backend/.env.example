# Inference mode: mock | cloud | claude-code | onprem
#   mock          — deterministic fixtures (no auth)
#   cloud         — pay-per-token Anthropic API (requires ANTHROPIC_API_KEY)
#   claude-code   — routes through the `claude` CLI; uses your Claude Code /
#                   Max subscription instead of API credits. Requires the
#                   `claude` CLI on PATH (Claude Code must be installed and
#                   logged in).
#   onprem        — local OCR (Tesseract); no outbound network
INFERENCE_MODE=mock

# Comma-separated list of allowed CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cloud provider (used when INFERENCE_MODE=cloud). One of: anthropic | openai | google
CLOUD_PROVIDER=anthropic
CLOUD_MODEL=claude-sonnet-4-6
# Provider API key (only one needed, matching CLOUD_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# On-prem (used when INFERENCE_MODE=onprem)
ONPREM_VLM_URL=http://localhost:11434
ONPREM_VLM_MODEL=phi3.5
