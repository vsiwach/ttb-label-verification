# Inference mode: mock | cloud | claude-code | onprem | sft
#   mock          — deterministic fixtures (no auth)
#   cloud         — pay-per-token Anthropic API (requires ANTHROPIC_API_KEY)
#   claude-code   — routes through the `claude` CLI; uses your Claude Code /
#                   Max subscription instead of API credits. Requires the
#                   `claude` CLI on PATH (Claude Code must be installed and
#                   logged in).
#   onprem        — local OCR (Tesseract); no outbound network
#   sft           — locally-fine-tuned VLM (Qwen2.5-VL LoRA or Donut).
#                   Bundle dir specified by SFT_MODEL_DIR. Requires
#                   `pip install -r backend/requirements-sft.txt`.
#   modal         — calls a Modal-hosted Qwen endpoint via HTTPS. No GPU
#                   needed locally. Set MODAL_ENDPOINT_URL to the deploy URL.
INFERENCE_MODE=modal

# Comma-separated list of allowed CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cloud provider (used when INFERENCE_MODE=cloud). One of: anthropic | openai | google
CLOUD_PROVIDER=anthropic
CLOUD_MODEL=claude-sonnet-4-6
# Provider API key (only one needed, matching CLOUD_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# On-prem (used when INFERENCE_MODE=onprem)
ONPREM_VLM_URL=http://localhost:11434
ONPREM_VLM_MODEL=phi3.5

# SFT (used when INFERENCE_MODE=sft). Point at a bundle dir containing
# manifest.json + (adapter/ for Qwen, model/ for Donut).
SFT_MODEL_DIR=backend/models/qwen2_5_vl_7b

# Modal-hosted Qwen (used when INFERENCE_MODE=modal). Set to the URL printed
# by `modal deploy backend/modal_deploy/serve_qwen.py`. Scale-to-zero, so cold
# starts add ~30-60s; bump MODAL_TIMEOUT if you hit timeouts on first request.
MODAL_ENDPOINT_URL=https://vsiwach--ttb-qwen-extractor-v2-extract-web.modal.run
MODAL_TIMEOUT=60
